# =============================================================================
# ADAL Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control - it contains sensitive information
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# PostgreSQL connection string (REQUIRED)
# Format: postgresql://username:password@host:port/database?sslmode=require
# For Neon.tech: Use the connection string from your Neon dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/adal_db?sslmode=require

# Local PostgreSQL (for heavy data and AI-related datasets)
# Format: postgresql://username:password@localhost:5432/database
# IMPORTANT for chat/drafting features:
# - This should point to the local PostgreSQL instance used for retrieval
# - The database should have pgvector enabled
# - The database should contain the legal_library table with embeddings loaded
LOCAL_DATABASE_URL=postgresql://postgres:password@localhost:5432/adal_local

# Supabase PostgreSQL (for online access and collaboration)
# Get from Supabase Dashboard → Settings → Database → Connection string
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Supabase REST API Configuration
# Get from Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Database Type: 'neon', 'local', 'hybrid', 'supabase'
# Use 'hybrid' for local PostgreSQL + Supabase setup
DATABASE_TYPE=hybrid

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
# Port for the FastAPI server (default: 9006)
PORT=9006

# Environment: development, staging, production
ENVIRONMENT=development

# API version
API_VERSION=1.0.0

# -----------------------------------------------------------------------------
# SECURITY & AUTHENTICATION
# -----------------------------------------------------------------------------
# SECRET_KEY: Generate a strong random key for production!
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Change this in production! Never use the default!
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Algorithm (default: HS256)
ALGORITHM=HS256

# Access token expiration time in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration time in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Toggle bearer-token auth for non-admin API routes.
# Default false keeps development workflow open.
AUTH_REQUIRED=false

# Toggle admin key guard for /api/admin/* routes.
# Default true to protect destructive admin actions even in development.
ADMIN_AUTH_REQUIRED=true

# Required when ADMIN_AUTH_REQUIRED=true.
# Send this value as X-Admin-Key request header.
ADMIN_API_KEY=set-me

# -----------------------------------------------------------------------------
# CORS CONFIGURATION
# -----------------------------------------------------------------------------
# Allowed origins for CORS (comma-separated)
# For development: http://localhost:3000,http://localhost:5173
# For production: https://yourdomain.com
# Note: if set to "*", backend forces allow_credentials=false.
# Use explicit origins to allow credentialed requests.
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# LLM CONFIGURATION
# -----------------------------------------------------------------------------
# LLM Provider: ollama (local), openai, anthropic
# Currently using Ollama (local, free)
LLM_PROVIDER=ollama

# Model name for Ollama (e.g., llama2, mistral, tinyllama)
# Make sure the model is installed: ollama pull <model_name>
LLM_MODEL_NAME=llama2

# Ollama base URL (default: http://localhost:11434)
LLM_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# CHAT & DRAFTING (DeepSeek / OpenAI-compatible API)
# -----------------------------------------------------------------------------
# The imported chat/drafting backend uses DeepSeek via the OpenAI-compatible SDK.
# For those routes, set DEEPSEEK_API_KEY and use a compatible model name such as:
#   LLM_MODEL_NAME=deepseek-chat
# If you keep LLM_MODEL_NAME=llama2, the older Ollama-based services may work,
# but the cleanup-core chat/drafting routes will not be configured correctly.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Legacy generic key fallback (only if you intentionally map another compatible provider):
# LLM_API_KEY=your_compatible_llm_api_key_here
# LLM_MODEL_NAME=deepseek-chat

# For Anthropic (if switching):
# LLM_API_KEY=sk-ant-your-anthropic-key-here
# LLM_MODEL_NAME=claude-3-sonnet

# -----------------------------------------------------------------------------
# EMBEDDING CONFIGURATION (BGE Model)
# -----------------------------------------------------------------------------
# BGE (BAAI General Embedding) model name
# Options: BAAI/bge-base-en-v1.5 (768 dim) or BAAI/bge-large-en-v1.5 (1024 dim)
BGE_MODEL_NAME=BAAI/bge-base-en-v1.5

# Embedding dimension (auto-detected from model, but can be set manually)
# bge-base: 768, bge-large: 1024
EMBEDDING_DIMENSION=768

# -----------------------------------------------------------------------------
# FAISS VECTOR DATABASE
# -----------------------------------------------------------------------------
# Path to FAISS index directory (relative to project root)
FAISS_INDEX_PATH=./data/faiss_index

# FAISS index name for legal documents (default: supreme_court_judgments)
FAISS_INDEX_NAME=supreme_court_judgments

# -----------------------------------------------------------------------------
# FILE STORAGE
# -----------------------------------------------------------------------------
# Maximum file upload size in MB (default: 25MB)
MAX_UPLOAD_SIZE_MB=25

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,txt

# Upload directory (relative to project root)
UPLOAD_DIR=./data/uploads

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# OPTIONAL: EXTERNAL SERVICES
# -----------------------------------------------------------------------------
# HuggingFace API token (for private models, optional)
# HUGGINGFACE_API_TOKEN=hf_your_token_here

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION (Caching & Session Management)
# -----------------------------------------------------------------------------
# Redis Host (default: localhost for WSL)
REDIS_HOST=localhost

# Redis Port (default: 6379)
REDIS_PORT=6379

# Redis Password (REQUIRED if password is set in redis.conf)
# If no password, leave empty or comment out
# Example: REDIS_PASSWORD=HAEmiLia_123
REDIS_PASSWORD=

# Redis Database Number (0-15, default: 0)
REDIS_DB=0

# Decode responses automatically (default: True)
REDIS_DECODE_RESPONSES=True

# Connection timeout settings (in seconds)
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Connection pool settings
REDIS_MAX_CONNECTIONS=50
REDIS_RETRY_ON_TIMEOUT=True

# Cache TTL settings (in seconds)
REDIS_CACHE_TTL=3600          # 1 hour for general cache
REDIS_SESSION_TTL=86400        # 24 hours for sessions
REDIS_DOCUMENT_CACHE_TTL=7200  # 2 hours for documents
REDIS_CITATION_CACHE_TTL=1800  # 30 minutes for citations

# -----------------------------------------------------------------------------
# DEVELOPMENT ONLY
# -----------------------------------------------------------------------------
# Enable debug mode (set to false in production)
DEBUG=true

# Enable auto-reload on code changes (development only)
RELOAD=true
