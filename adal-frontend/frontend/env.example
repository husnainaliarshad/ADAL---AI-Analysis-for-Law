# =============================================================================
# ADAL Frontend Environment Configuration
# =============================================================================
# Copy to `.env` and adjust values for your environment.
#
# Canonical API variable:
#   - VITE_API_URL
# Transitional fallback (deprecated):
#   - VITE_API_BASE_URL
# =============================================================================

# Canonical backend API URL (must include /api)
# Example: http://localhost:9006/api
VITE_API_URL=http://localhost:9006/api

# Deprecated fallback used only when VITE_API_URL is not set.
# Example: http://localhost:9006
# VITE_API_BASE_URL=http://localhost:9006

# Explicit opt-in for unauthenticated dev preview routes (/__dev__/...)
# Default behavior is disabled unless this is exactly "true".
VITE_ENABLE_DEV_ROUTES=false

# Notifications endpoint feature flag.
# Keep false until backend /notifications APIs are available.
VITE_ENABLE_NOTIFICATIONS_API=false

# Debug logs (frontend logger).
# Set to true for verbose client logs in development.
VITE_DEBUG=false

# Optional app environment label
VITE_ENV=development

# ----------------------------------------------------------------------------
# Quick verification commands (run from frontend folder)
# ----------------------------------------------------------------------------
# 1) Validate there are no UTF-16 files under src:
#    find src -type f -print0 | xargs -0 file -bi | grep -i "utf-16"
#
# 2) Start dev server:
#    npm run dev
# ----------------------------------------------------------------------------
